rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"developer_instructions\":\"The user opened the Memory settings entrypoint to understand what ChatGPT knows about them.\\nAnswer with a concise profile summary using clear headings.\\nSeparate stable facts and preferences from softer inferences when that distinction is useful.\\nDo not list raw memory records or internal implementation details.\\nIf there is little usable memory or personalization context, say that plainly and suggest what the user can tell ChatGPT to improve personalization.\",\"prefilled_prompt\":\"What do you know about me? Give me a 5 paragraph summary, with headings.\"},\"is_device_based\":false,\"passed\":false},\"1426425582\":{\"name\":\"1426425582\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":true},\"is_device_based\":false,\"group_name\":\"Live-only create\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"1598825633\":{\"name\":\"1598825633\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"denominator\":0,\"enabled\":true},\"is_device_based\":false,\"passed\":false},\"462023397\":{\"name\":\"462023397\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"detection_sources\":[\"image_element_probe_v1\",\"parse_visibility_mutation_v1\",\"ad_options_dom_removal_v1\"],\"memoize_detection_for_session\":false,\"detection_source\":\"image_element_probe_v1\"},\"is_device_based\":false,\"passed\":false},\"3359927663\":{\"name\":\"3359927663\",\"rule_id\":\"4PJfVH44agUI1KA3nvdZUW:0.00:2-6zr8aU9VHNUkRPlG8CwXPB\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"max_pending_update_header_size_bytes\":0,\"enabled\":false},\"is_device_based\":true,\"passed\":false},\"730493191\":{\"name\":\"730493191\",\"rule_id\":\"default\",\"secondary_exposures\":[{\"gate\":\"1584773534\",\"gateValue\":\"false\",\"ruleID\"